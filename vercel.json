{
  "version": 2,
  "functions": {
    "api/index.ts": {
      "excludeFiles": "{public/data,*.db,scripts,dist,node_modules/.cache}/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
